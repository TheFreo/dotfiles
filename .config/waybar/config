{
  "position": "bottom",
    "margin-top" : 0,
    "margin-left": 0,
    "margin-right": 0,
    "height" : 28,
    "modules-left": [
      "custom/media",
      "hyprland/window"
    ],
    "modules-center": [
      "1hyprland/workspaces",
    ],
    "modules-right": [
    //"hyprland/language",
    "pulseaudio",
    "battery",
    "network",
    "clock",
    "custom/notification",
    ],
    "custom/media": {
    "interval": 90,
    "exec": "~/.config/waybar/settings/mediaexec.sh",
    "on-click": "~/.config/waybar/settings/mediatoggle.sh"
    },
    "hyprland/window": {
      "format": "{}",
      "max-length": 35,
      "rewrite": {
        "": "(╦ÂßÁö ßÁĽ ßÁö╦Â)"
      },
      "separate-outputs": true,
    },
        "network": {
        "interface": "wlan*", // (Optional) To force the use of this interface
        "format-wifi": "<span color='#ffffff'> / </span><span color='#ffffff'>wlan:</span> <span color='#ffffff'>on</span>",
        "format-ethernet": "{ipaddr}/{cidr} ´×ľ",
        "tooltip-format": "{ifname} via {gwaddr} ´×ľ",
        "format-linked": "{ifname} (No IP) ´×ľ",
        "format-disconnected": "<span color='#ffffff'> / </span><span color='#ffffff'>wlan:</span> <span color='#ffffff'>off</span>",
        "format-alt": "<span color='#ffffff'> / </span>{essid} ({signalStrength}%)"
    },
    "hyprland/workspaces": {
      "format": "{icon}",
      "on-click": "activate",
      "format-icons": {
        "active": "´äĹ ",
      },
      "sort-by-number": true,
      "persistent-workspaces": {
        "*": 4, // 5 workspaces by default on every monitor
        "HDMI-A-1": 3 // but only three on HDMI-A-1
      },
    },
    "clock": {
      "format": "<span color='#ffffff'> / </span>{:%H:%M} ",
      "tooltip-format": "<big>{:%d-%m %A}</big>\n<tt><small>{calendar}</small></tt>",
      "format-alt": "<span color='#ffffff'> / </span>{:%d-%m-%Y} "
    },
    "cpu": {
      "format": " {usage}%",
      "tooltip": false
    },
    "memory": {
      "format": "{}% "
    },
    "temperature": {
      "critical-threshold": 80,
      "format": "{icon} {temperatureC}┬░C",
      "format-icons": ["´Łź", "´őë", "´Łę"]
    },
    "pulseaudio": {
      "format": "<span color='#ffffff'>vol:</span> <span color='#ffffff'>{volume}%</span>",
      "format-bluetooth": "<span color='#ffffff'>vol:</span> <span color='#ffffff'>{volume}%</span>",
      "format-bluetooth-muted": "´Üę {icon}´Őö",
      "format-muted": "<span color='#ffffff'>vol:</span> <span color='#ffffff'>0%</span>",
      "format-icons": {
        "headphone": "´Çą",
        "hands-free": "´ľÉ",
        "headset": "´ľÉ",
        "phone": "´éĽ",
        "portable": "´éĽ",
        "car": "´ć╣",
        "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
      },
      "on-click": "pavucontrol"
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "<span color='#ffffff'> / </span><span color='#ffffff'>bat:</span> <span color='#ffffff'>{capacity}%</span>",
        "format-charging": "<span color='#ffffff'> / </span><span color='#ffffff'>ac:</span> <span color='#ffffff'>{capacity}%</span>",
        "format-plugged": "´çŽ {capacity}%",
        // "format-alt": "{icon} {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["´ëä ", "´ëâ ", "´ëé ", "´ëü ", "´ëÇ "]
    },
    "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "<span foreground='#ffffff'>´Ĺä</span>",
      "none": " ",
      "dnd-notification": "´çĚ<span foreground='#ffffff'><sup>´Ĺä</sup></span>",
      "dnd-none": " ",
      "inhibited-notification": "<span foreground='#ffffff'>´Ĺä</span>",
      "inhibited-none": " ",
      "dnd-inhibited-notification": "´çĚ<span foreground='#ffffff'><sup>´Ĺä</sup></span>",
      "dnd-inhibited-none": " "
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },


}
